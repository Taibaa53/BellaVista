# Supabase PostgreSQL (Project Settings → Database → URI)
DATABASE_URL="postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres?sslmode=require"
PORT=5000

# Admin dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_JWT_SECRET=generate-a-random-secret-here

# Optional: Nodemailer for order notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=your-admin-email@gmail.com
