{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "server/src/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "client/index.html"
        }
    ],
    "functions": {
        "server/src/index.js": {
            "runtime": "nodejs20.x"
        }
    }
}